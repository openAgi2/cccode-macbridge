.DS_Store

# Go build outputs
/cccode-bridge-runtime
/go-bridge/go-bridge
/go-bridge/cccode-bridge-runtime
/relay-server/relay-server
/relay-server/cmd/relay-server/relay-server
/relay-server/build/

# Xcode and local build products
/MacBridge/build/
/build/
/dist/
DerivedData/
*.xcuserstate
xcuserdata/

# Local runtime state
*.log
*.tmp

# Agent memory files — local only, not shared via git
CLAUDE.md
AGENTS.md

# docs/ work notes — local-only (plans/specs/reviews/completion reports)
# All future docs/ additions stay local too. Already-tracked files are
# unaffected by .gitignore. Re-include docs/protocol/ so the protocol
# source-of-truth can still be added/updated; project docs (install/
# release/signing) remain tracked as already-committed.
/docs/*
!/docs/protocol/
